<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <!-- Naziv (gore, veći font) -->
    <TextView
        android:id="@+id/tvNaziv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Charizard"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/imgPokemon"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Tip (dolje, manji font) -->
    <TextView
        android:id="@+id/tvTip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Fire/Flying"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/imgPokemon"
        app:layout_constraintTop_toBottomOf="@id/tvNaziv"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Slika (desno) -->
    <ImageView
        android:id="@+id/imgPokemon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/charizard"
        android:contentDescription="Pokemon slika"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>