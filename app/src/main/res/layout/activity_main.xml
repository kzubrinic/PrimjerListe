<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">




    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Switch
            android:id="@+id/switchOrijentacije"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Horizontalna orijentacija liste" />

        <EditText
            android:id="@+id/brojStupaca"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ems="10"
            android:hint="Broj stupaca grida"
            android:text="2"
            android:inputType="number" />
    </LinearLayout>



    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/najjednostavnija"
        android:id="@+id/najjednostavnijiMenu"
        android:layout_gravity="center_horizontal" />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/jednostavna"
        android:id="@+id/jednostavnaMenu"
        android:layout_gravity="center_horizontal" />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/slozena"
        android:id="@+id/slozenaMenu"
        android:layout_gravity="center_horizontal" />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/gridSlozena"
        android:id="@+id/gridMenu"
        android:layout_gravity="center_horizontal" />
</LinearLayout>